# ========================
# Server Configuration
# ========================
PORT=3001
NODE_ENV=development

# ========================
# Firebase Admin SDK
# ========================
FIREBASE_PROJECT_ID=covelet-a8121

# Path to your Firebase service account key JSON file
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# Alternative: paste the entire service account JSON as a single-line string
# (useful for Render/Heroku where you can't upload files)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ========================
# CORS / Client
# ========================
# For mobile apps, CORS is not enforced by the client.
# Set this to the web client origin if you have a web build.
CLIENT_URL=http://localhost:8081
